{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "notification:default",
    "dialog:default",
    "core:path:default",
    "fs:default",
    "fs:allow-appdata-write-recursive",
    "fs:allow-applocaldata-write-recursive",
    "fs:allow-home-write-recursive"
  ]
}
